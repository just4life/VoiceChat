# Next.js runtime
NODE_ENV=production
PORT=3000

# Prisma + SQLite (stored in Docker volume mounted to /app/data)
DATABASE_URL="file:/app/data/voicechat.db"

# Comma-separated list of admin GUIDs
ADMIN_GUIDS="replace-with-admin-guid-1,replace-with-admin-guid-2"

# WebSocket signalling server
WS_PORT=3001
# URL for browser clients (used when wiring WebSocket client-side)
NEXT_PUBLIC_WS_URL="wss://your-domain.example/ws"
